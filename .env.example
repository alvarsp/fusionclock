# ── Required ──────────────────────────────────────────────────────────────────
# Your Oracle Fusion base URL (no trailing slash)
ORACLE_URL=https://your-instance.oraclecloud.com

# ── Optional but highly recommended ───────────────────────────────────────────
# Direct URL to the Time/Clock page — skips navigation, much more reliable
# TIME_NAV_URL=https://your-instance.oraclecloud.com/hcmUI/faces/...

# SSO domain hint for session-expiry detection
# SSO_DOMAIN=yourcompany.okta.com

# Path to an existing Chrome user-data-dir (used by `setup` to reuse your session)
# On macOS the default Chrome profile is at:
# ~/Library/Application Support/Google/Chrome
# To avoid locking your main Chrome, use a dedicated profile directory instead:
CHROME_PROFILE_DIR=/Users/you/chrome-fusion-cdp-profile

# ── Button selectors ──────────────────────────────────────────────────────────
# Override these if the defaults don't match your Oracle Fusion configuration.
# Use "text=..." for text matching or a CSS/XPath selector.
# CLOCK_IN_SELECTOR=text=Clock In
# CLOCK_OUT_SELECTOR=text=Clock Out

# ── Check-in window (9:00 + 0–15 min) ────────────────────────────────────────
CHECKIN_DELAY_MIN=0
CHECKIN_DELAY_MAX=15

# ── Check-out window (17:45 + 0–15 min) ──────────────────────────────────────
CHECKOUT_DELAY_MIN=0
CHECKOUT_DELAY_MAX=15

# ── Notifications ─────────────────────────────────────────────────────────────
# Slack / Discord / any webhook that accepts POST {"text": "..."}
# NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── Server settings ───────────────────────────────────────────────────────────
# Where session.json and screenshots are stored
# DATA_DIR=/opt/oracle-clock/data

# Set to false to see the browser (useful for debugging)
HEADLESS=true

# Page-load timeout in milliseconds
TIMEOUT_MS=30000
